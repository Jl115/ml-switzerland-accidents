    "\n",
    "### Step 5.2: Understand Gini Impurity\n",
    "\n",
    "**What to do:**\n",
    "- Learn the Gini formula\n",
    "- Calculate Gini by hand for a small example\n",
    "\n",
    "**Why:** This is how the tree decides which feature to split on\n",
    "\n",
    "**Resources:**\n",
    "- 📹 [Gini Impurity (StatQuest)](https://www.youtube.com/watch?v=9h3z5vTqPJA)\n",
    "\n",
    "**Time:** 1 hour\n",
    "\n",
    "**Your Task:**\n",
    "```python\n",
    "import numpy as np\n",
    "\n",
    "def gini_impurity(y):\n",
    "    \"\"\"\n",
    "    Calculate Gini impurity for an array of labels.\n",
    "    \n",
    "    Example:\n",
    "    y = [0, 0, 1, 1, 2]  # 5 samples, 3 classes\n",
    "    \"\"\"\n",
    "    n = len(y)\n",
    "    if n == 0:\n",
    "        return 0\n",
    "    \n",
    "    # Get unique classes and their counts\n",
    "    _, counts = np.unique(y, return_counts=True)\n",
    "    \n",
    "    # Calculate probabilities\n",
    "    probs = counts / n\n",
    "    \n",
    "    # Gini = 1 - sum(p²)\n",
    "    gini = 1 - np.sum(probs ** 2)\n",
    "    \n",
    "    return gini\n",
    "\n",
    "# Test it\n",
    "# Pure node (all same class) - should be 0\n",
    "pure = [1, 1, 1, 1]\n",
    "print(f\"Pure node Gini: {gini_impurity(pure)}\")  # Should be 0\n",
    "\n",
    "# Impure node (mixed classes) - should be > 0\n",
    "impure = [0, 0, 1, 1, 2, 2]\n",
    "print(f\"Impure node Gini: {gini_impurity(impure):.3f}\")  # Should be ~0.667\n",
    "\n",
    "# Maximum impurity (equal distribution)\n",
    "max_impure = [0, 1, 2, 3]\n",
    "print(f\"Max impurity Gini: {gini_impurity(max_impure):.3f}\")  # Should be 0.75\n",
    "```\n",
    "\n",
    "**✅ Check:** Can you calculate Gini by hand? Move to next step!\n",
    "\n",
    "---\n",
    "\n",
    "### Step 5.3: Understand Information Gain\n",
    "\n",
    "**What to do:**\n",
    "- Learn how to evaluate splits\n",
    "- Calculate information gain\n",
    "\n",
    "**Why:** The tree picks the split with highest information gain\n",
    "\n",
    "**Resources:**\n",
    "- 📹 [Information Gain (StatQuest)](https://www.youtube.com/watch?v=LDRbO9a6XPU)\n",
    "\n",
    "**Time:** 1 hour\n",
    "\n",
    "**Your Task:**\n",
    "```python\n",
    "import numpy as np\n",
    "\n",
    "def entropy(y):\n",
    "    \"\"\"Calculate entropy (alternative to Gini)\"\"\"\n",
    "    n = len(y)\n",
    "    if n == 0:\n",
    "        return 0\n",
    "    _, counts = np.unique(y, return_counts=True)\n",
    "    probs = counts / n\n",
    "    entropy = -np.sum(probs * np.log2(probs))\n",
    "    return entropy\n",
    "\n",
    "def information_gain(y, y_left, y_right):\n",
    "    \"\"\"\n",
    "    Calculate information gain from a split.\n",
    "    \n",
    "    Gain = Parent Entropy - Weighted Child Entropy\n",
    "    \"\"\"\n",
    "    n = len(y)\n",
    "    n_left, n_right = len(y_left), len(y_right)\n",
    "    \n",
    "    if n_left == 0 or n_right == 0:\n",
    "        return 0\n",
    "    \n",
    "    parent_entropy = entropy(y)\n",
    "    child_entropy = (n_left / n) * entropy(y_left) + (n_right / n) * entropy(y_right)\n",
    "    gain = parent_entropy - child_entropy\n",
    "    \n",
    "    return gain\n",
    "\n",
    "# Test it\n",
    "parent = [0, 0, 0, 1, 1, 1, 2, 2]\n",
    "left = [0, 0, 0]  # Pure left\n",
    "right = [1, 1, 1, 2, 2]  # Mixed right\n",
    "\n",
    "gain = information_gain(parent, left, right)\n",
    "print(f\"Information Gain: {gain:.3f}\")\n",
    "```\n",
    "\n",
    "**✅ Check:** Can you explain why high information gain is good? Week 5 complete! 🎉\n",
