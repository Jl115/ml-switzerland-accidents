    "---\n",
    "\n",
    "### Step 6.2: Implement Gini and Split Finding\n",
    "\n",
    "**What to do:**\n",
    "- Add `gini_impurity()` method\n",
    "- Add `_find_best_split()` method\n",
    "\n",
    "**Time:** 2-3 hours\n",
    "\n",
    "**Your Task:**\n",
    "```python\n",
    "def _gini_impurity(self, y):\n",
    "    \"\"\"Calculate Gini impurity\"\"\"\n",
    "    n = len(y)\n",
    "    if n == 0:\n",
    "        return 0\n",
    "    _, counts = np.unique(y, return_counts=True)\n",
    "    probs = counts / n\n",
    "    return 1 - np.sum(probs ** 2)\n",
    "\n",
    "def _find_best_split(self, X, y):\n",
    "    \"\"\"\n",
    "    Find the best feature and threshold to split on.\n",
    "    \n",
    "    Returns: best_feature, best_threshold, best_gain\n",
    "    \"\"\"\n",
    "    n_samples, n_features = X.shape\n",
    "    best_gain = -1\n",
    "    best_feature = None\n",
    "    best_threshold = None\n",
    "    \n",
    "    # Try each feature\n",
    "    for feature_idx in range(n_features):\n",
    "        # Get unique thresholds to try\n",
    "        thresholds = np.unique(X[:, feature_idx])\n",
    "        \n",
    "        # Try each threshold\n",
    "        for threshold in thresholds:\n",
    "            # Split data\n",
    "            left_mask = X[:, feature_idx] <= threshold\n",
    "            right_mask = ~left_mask\n",
    "            \n",
    "            y_left = y[left_mask]\n",
    "            y_right = y[right_mask]\n",
    "            \n",
    "            # Skip if split creates empty node\n",
    "            if len(y_left) == 0 or len(y_right) == 0:\n",
    "                continue\n",
    "            \n",
    "            # Calculate information gain\n",
    "            gain = self._information_gain(y, y_left, y_right)\n",
    "            \n",
    "            # Update best if this is better\n",
    "            if gain > best_gain:\n",
    "                best_gain = gain\n",
    "                best_feature = feature_idx\n",
    "                best_threshold = threshold\n",
    "    \n",
    "    return best_feature, best_threshold, best_gain\n",
    "```\n",
    "\n",
    "**✅ Check:** Can you find the best split for a small dataset? Move to next step!\n",
    "\n",
    "---\n",
    "\n",
    "### Step 6.3: Implement Recursive Tree Building\n",
    "\n",
    "**What to do:**\n",
    "- Implement `_build_tree()` with recursion\n",
    "- Handle stopping criteria\n",
    "\n",
    "**Time:** 3-4 hours\n",
    "\n",
    "**Your Task:**\n",
    "```python\n",
    "def _build_tree(self, X, y, depth):\n",
    "    \"\"\"\n",
    "    Recursively build the decision tree.\n",
    "    \n",
    "    Returns: Dictionary representing a node\n",
    "    \"\"\"\n",
    "    n_samples = len(y)\n",
    "    \n",
    "    # Check stopping criteria\n",
    "    if (depth >= self.max_depth or \n",
    "        n_samples < self.min_samples_split or\n",
    "        len(np.unique(y)) == 1):  # All same class\n",
    "        # Create leaf node\n",
    "        return {'leaf': True, 'prediction': self._most_common_label(y)}\n",
    "    \n",
    "    # Find best split\n",
    "    feature, threshold, gain = self._find_best_split(X, y)\n",
    "    \n",
    "    # If no good split found, create leaf\n",
    "    if feature is None or gain == 0:\n",
    "        return {'leaf': True, 'prediction': self._most_common_label(y)}\n",
    "    \n",
    "    # Split data\n",
    "    left_mask = X[:, feature] <= threshold\n",
    "    right_mask = ~left_mask\n",
    "    \n",
    "    # Recursively build left and right subtrees\n",
    "    left_subtree = self._build_tree(X[left_mask], y[left_mask], depth + 1)\n",
    "    right_subtree = self._build_tree(X[right_mask], y[right_mask], depth + 1)\n",
    "    \n",
    "    # Return internal node\n",
    "    return {\n",
    "        'leaf': False,\n",
    "        'feature': feature,\n",
    "        'threshold': threshold,\n",
    "        'left': left_subtree,\n",
    "        'right': right_subtree\n",
    "    }\n",
    "\n",
    "def _most_common_label(self, y):\n",
    "    \"\"\"Return the most common label in y\"\"\"\n",
    "    labels, counts = np.unique(y, return_counts=True)\n",
    "    return labels[np.argmax(counts)]\n",
    "```\n",
    "\n",
    "**✅ Check:** Can you build a tree and print its structure? Move to next step!\n",
    "\n",
    "---\n",
    "\n",
    "### Step 6.4: Implement Predict Method\n",
    "\n",
    "**What to do:**\n",
    "- Implement `predict()` to traverse the tree\n",
    "- Test on your Uri data\n",
    "\n",
